            "example": "request",
            "description": "Lead-phase statuses (request, contacted, quote_sent, inspection, lost) are returned by GET /leads; job-phase statuses (pending, scheduled, in_progress, completed, cancelled) by GET /work-items."
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "urgent"
            ],
            "example": "medium"
          },
          "category": {
            "type": "string",
            "nullable": true,
            "example": "Loodgieter"
          },
          "customerSignature": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "scheduledStart": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "scheduledEnd": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "actualStart": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "actualEnd": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "source": {
            "type": "string",
            "enum": [
              "web",
              "phone",
              "chat",
              "referral",
              "other",
              "whatsapp",
              "email",
              "manual"
            ],
            "example": "web"
          },
          "receivedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-17T10:30:45.000Z"
          },
          "addressId": {
            "type": "string",
            "nullable": true,
            "example": "ADRabc123def456ghi789jkl"
          },
          "customStatusId": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "estimatedCost": {
            "type": "number",
            "nullable": true,
            "example": null,
            "description": "Estimated cost in cents."
          },
          "finalCost": {
            "type": "number",
            "nullable": true,
            "example": null,
            "description": "Final cost in cents."
          },
          "budgetQuote": {
            "type": "string",
            "nullable": true,
            "example": "€500 - €1000"
          },
          "notes": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "completionNotes": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "tags": {
            "nullable": true,
            "example": null,
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "customer": {
            "description": "Populated in the list endpoints (GET /leads, GET /work-items).",
            "allOf": [
              {
                "$ref": "#/components/schemas/CustomerResponseDto"
              }
            ]
          },
          "address": {
            "nullable": true,
            "description": "Populated in the list endpoints; null when the lead is address-less.",
            "allOf": [
              {
                "$ref": "#/components/schemas/AddressResponseDto"
              }
            ]
          },
          "photos": {
            "description": "Present only when photoUrls were supplied. One entry per URL, in order.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LeadPhotoResultDto"
            }
          }
        },
        "required": [
          "createdAt",
          "updatedAt",
          "createdBy",
          "updatedBy",
          "deletedAt",
          "archivedAt",
          "id",
          "brandId",
          "customerId",
          "title",
          "description",
          "status",
          "priority",
          "category",
          "customerSignature",
          "scheduledStart",
          "scheduledEnd",
          "actualStart",
          "actualEnd",
          "source",
          "receivedAt",
          "addressId",
          "customStatusId",
          "estimatedCost",
          "finalCost",
          "budgetQuote",
          "notes",
          "completionNotes",
          "tags"
        ]
      },
      "WorkItemListResponseDto": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkItemResponseDto"
            }
          },
          "limit": {
            "type": "number",
            "example": 50,
            "description": "Effective limit applied (max 100)."
          }
        },
        "required": [
          "data",
          "limit"
        ]
      }
    }
  }
}
