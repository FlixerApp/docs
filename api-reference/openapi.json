      "post": {
        "description": "Creates a customer and work item (and an address when one is supplied) in one call, linked together automatically. Address is optional: lead sources like Meta/Facebook Lead Ads collect only name/email/phone, so a lead with no street/postalCode/city is created address-less. Photos are optional: pass publicly downloadable https URLs in photoUrls (max 10) and they are downloaded and attached to the lead as assets. Photo ingestion is best-effort — failures never fail the lead and are reported per URL in the `photos` field of the response. Customers are deduplicated: when a non-archived customer in the brand matches the submitted email (case-insensitive) or phone (last 9 digits), the lead is attached to that customer instead of creating a duplicate. On email matches, a missing phone/address on the existing record is backfilled and noted on the lead; phone-matched records are never modified (the submitted email did not match, so it is not trusted).",
        "operationId": "PublicLeadController_create_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLeadDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateLeadResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed (e.g. missing customerName or title).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, or revoked X-API-Key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDto"
                }
              }
            }
          },
          "403": {
            "description": "The API key lacks the scope required for this endpoint.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "api-key": []
          }
        ],
        "summary": "Create a new lead",
        "tags": [
          "Leads"
        ]
      }
    },
