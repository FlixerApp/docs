  "components": {
    "securitySchemes": {
      "api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "ErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 400,
            "description": "HTTP status code."
          },
          "message": {
            "type": "string",
            "example": "customerName is required",
            "description": "Human-readable error message. For validation errors this may be an array of strings, one per failed field."
          },
          "error": {
            "type": "string",
            "example": "Bad Request",
            "description": "HTTP status text."
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "AddressResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "ADRabc123def456ghi789jkl"
          },
          "brandId": {
            "type": "string",
            "example": "BRDabc123def456ghi789jkl"
          },
          "country": {
            "type": "string",
            "nullable": true,
            "example": "Nederland"
          },
          "stateProvince": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "city": {
            "type": "string",
            "example": "Amsterdam"
          },
          "postalCode": {
            "type": "string",
            "example": "1015 CJ"
          },
          "street": {
            "type": "string",
            "example": "Keizersgracht"
          },
          "streetNumber": {
            "type": "string",
            "nullable": true,
            "example": "123"
          },
          "streetNumberAddition": {
            "type": "string",
            "nullable": true,
            "example": "A"
          },
          "latitude": {
            "type": "number",
            "nullable": true,
            "example": 52.3676
          },
          "longitude": {
            "type": "number",
            "nullable": true,
            "example": 4.9041
          },
          "locationNotes": {
            "type": "string",
            "nullable": true,
            "example": null
          }
        },
        "required": [
          "id",
          "brandId",
          "country",
          "stateProvince",
          "city",
          "postalCode",
          "street",
          "streetNumber",
          "streetNumberAddition",
          "latitude",
          "longitude",
          "locationNotes"
        ]
      },
