{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Flixer Pro API",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#0057FF",
    "light": "#0057FF",
    "dark": "#0057FF"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Handleidingen",
        "groups": [
          {
            "group": "Aan de slag",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Handleidingen",
            "pages": [
              "guides/lead-capture",
              "guides/data-sync"
            ]
          },
          {
            "group": "Referentie",
            "pages": [
              "error-handling"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Leads",
            "pages": [
              "api-reference/endpoint/leads/list-all-leads",
              "api-reference/endpoint/leads/create-a-new-lead"
            ]
          },
          {
            "group": "Work Items",
            "pages": [
              "api-reference/endpoint/work-items/list-all-work-items-opdrachten"
            ]
          },
          {
            "group": "Addresses",
            "pages": [
              "api-reference/endpoint/address/list-all-addresses"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.flixerpro.io",
          "icon": "browser"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/flixer-pro-logo.svg",
    "dark": "/logo/flixer-pro-logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.flixerpro.io"
      }
    ]
  },
  "openapi": "api-reference/openapi.json",
  "api": {
    "baseUrl": "https://api.flixerpro.io/v1",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    }
  },
  "footer": {
    "socials": {
      "website": "https://flixerpro.io"
    }
  }
}
